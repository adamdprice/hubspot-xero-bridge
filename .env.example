# HubSpot private app token — Settings → Integrations → Private apps (CRM: deals, contacts, companies)
HUBSPOT_ACCESS_TOKEN=

# Set false until custom deal properties exist (see below). When true, the app reads/writes Xero IDs on the deal.
HUBSPOT_DEAL_SYNC_ENABLED=false

# Xero OAuth app (developer.xero.com). Refresh token is NOT shown in the portal — only after browser OAuth.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# After visiting /auth/xero/start and approving access, paste from the success page:
XERO_REFRESH_TOKEN=
XERO_TENANT_ID=

# Must match a redirect URI on your Xero app exactly (use localhost, not 127.0.0.1).
# If you use ngrok, set this to https://YOUR-SUBDOMAIN.ngrok-free.app/auth/xero/callback and add the same URL in Xero.
XERO_REDIRECT_URI=http://localhost:8080/auth/xero/callback

# Optional: override OAuth scopes (space-separated). New apps (from Mar 2026) need granular scopes —
# the bridge defaults to accounting.invoices + accounting.contacts + accounting.settings (not accounting.transactions).
# XERO_OAUTH_SCOPES=openid profile email offline_access accounting.invoices accounting.contacts accounting.settings

# Line defaults — must match your Xero org (Items, Chart of accounts, Tax rates)
XERO_SALES_ACCOUNT_CODE=200
XERO_ITEM_CODE=Day Rate (VAT)
# Tax type for VAT on sales (org-specific). UK standard rate sales often OUTPUT2 — confirm in Xero → Settings → Tax rates
XERO_LINE_TAX_TYPE=OUTPUT2

# Public HTTPS URL where the FastAPI app is reachable (ngrok, Cloudflare Tunnel, etc.).
# Use the same value as BRIDGE_BASE_URL in hubspot-ui-extension/src/app/cards/XeroBridgeInvoice.jsx
# PUBLIC_BRIDGE_URL=https://your-subdomain.ngrok-free.app

# --- Public deploy (Railway, etc.) — lock down the UI + APIs ---
# Generate: openssl rand -hex 32
# Set the same value in hubspot-ui-extension BRIDGE_AUTH_TOKEN and run hs project upload.
# BRIDGE_AUTH_TOKEN=
# Use HTTPS-only session cookies on the public host (Railway sets HTTPS).
# BRIDGE_COOKIE_SECURE=true
# Optional: separate signing key for cookie sessions (>=32 chars); else derived from BRIDGE_AUTH_TOKEN
# BRIDGE_SESSION_SECRET=

# Deal properties — create under Settings → Data management → Objects → Deals → Properties
# (single-line text). Internal names must match. Then set HUBSPOT_DEAL_SYNC_ENABLED=true.
HUBSPOT_DEAL_PROP_XERO_CONTACT_ID=xero_contact_id
HUBSPOT_DEAL_PROP_XERO_INVOICE_ID=xero_invoice_id
HUBSPOT_DEAL_PROP_XERO_SYNC_KEY=xero_sync_idempotency_key
HUBSPOT_DEAL_PROP_XERO_LAST_ERROR=xero_sync_last_error
