# HubSpot private app token — Settings → Integrations → Private apps (CRM: deals, contacts, companies)
HUBSPOT_ACCESS_TOKEN=
# Same app: Client secret (Auth tab). Required for webhook POSTs when BRIDGE_AUTH_TOKEN is set — validates X-HubSpot-Signature (HubSpot cannot send custom headers).
# HUBSPOT_CLIENT_SECRET=

# Xero OAuth app (developer.xero.com). Refresh token is NOT shown in the portal — only after browser OAuth.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# After visiting /auth/xero/start and approving access, paste from the success page:
XERO_REFRESH_TOKEN=
XERO_TENANT_ID=

# Persist rotated refresh tokens on disk (recommended). Stops Railway env vars going stale when Xero rotates.
# On Railway: add a volume (e.g. mount /data). Set either:
#   XERO_TOKEN_SQLITE_PATH=/data/xero_tokens.db
#   XERO_TOKEN_SQLITE_PATH=/data
# (a directory is OK — we append xero_tokens.db). Or omit XERO_TOKEN_SQLITE_PATH and use
# RAILWAY_VOLUME_MOUNT_PATH/xero_tokens.db when Railway sets it.
# If you see "unable to open database file", set on the Railway service:
#   RAILWAY_RUN_UID=0
# (Volumes mount as root; the app must run as root to write there, unless your image matches.)
# Default without a volume is /tmp/hubspot_xero_tokens.db (lost on redeploy).
# XERO_DISABLE_TOKEN_STORE=1

# Must match a redirect URI on your Xero app exactly (use localhost, not 127.0.0.1).
# If you use ngrok, set this to https://YOUR-SUBDOMAIN.ngrok-free.app/auth/xero/callback and add the same URL in Xero.
XERO_REDIRECT_URI=http://localhost:8080/auth/xero/callback

# Optional: override OAuth scopes (space-separated). New apps (from Mar 2026) need granular scopes —
# the bridge defaults to accounting.invoices + accounting.contacts + accounting.settings (not accounting.transactions).
# XERO_OAUTH_SCOPES=openid profile email offline_access accounting.invoices accounting.contacts accounting.settings

# Line defaults — must match your Xero org (Items, Chart of accounts, Tax rates)
XERO_SALES_ACCOUNT_CODE=200
XERO_ITEM_CODE=Day Rate (VAT)
# Tax type for VAT on sales (org-specific). UK standard rate sales often OUTPUT2 — confirm in Xero → Settings → Tax rates
XERO_LINE_TAX_TYPE=OUTPUT2
# Xero org limits (Developer docs): ~60 calls/minute, max 5 concurrent in flight, daily cap often ~5,000/day — 429 until reset.
# Process-wide minimum seconds between Accounting API responses (default 3.0 ≈ 20/min). Raise if 429 persists; reduce cron batch / disable timer if day limit hits.
# XERO_API_MIN_INTERVAL_SECONDS=3.0

# Public HTTPS URL where the FastAPI app is reachable (ngrok, Cloudflare Tunnel, etc.).
# Use the same value as BRIDGE_BASE_URL in hubspot-ui-extension/src/app/cards/XeroBridgeInvoice.jsx
# PUBLIC_BRIDGE_URL=https://your-subdomain.ngrok-free.app

# --- Public deploy (Railway, etc.) — lock down the UI + APIs ---
# Generate: openssl rand -hex 32
# Set the same value in hubspot-ui-extension BRIDGE_AUTH_TOKEN and run hs project upload.
# BRIDGE_AUTH_TOKEN=
# Use HTTPS-only session cookies on the public host (Railway sets HTTPS).
# BRIDGE_COOKIE_SECURE=true
# Optional: separate signing key for cookie sessions (>=32 chars); else derived from BRIDGE_AUTH_TOKEN
# BRIDGE_SESSION_SECRET=

# Deal properties — create under Settings → Data management → Objects → Deals → Properties
# (single-line text). Internal names must match.
HUBSPOT_DEAL_PROP_XERO_CONTACT_ID=xero_contact_id
HUBSPOT_DEAL_PROP_XERO_INVOICE_ID=xero_invoice_id
HUBSPOT_DEAL_PROP_XERO_INVOICE_NUMBER=xero_invoice_number
HUBSPOT_DEAL_PROP_XERO_INVOICE_STATUS=xero_invoice_status
HUBSPOT_DEAL_PROP_XERO_SYNC_KEY=xero_sync_idempotency_key
HUBSPOT_DEAL_PROP_XERO_LAST_ERROR=xero_sync_last_error
# Optional — legacy boolean sync flag (omit or leave unset if you only use the dropdown trigger)
# HUBSPOT_DEAL_PROP_SYNC_WITH_XERO=sync_with_xero
# Dropdown trigger (single option "Sync" by default) — override if your HubSpot internal value differs
# HUBSPOT_DEAL_PROP_XERO_SYNC_TRIGGER=xero_sync_trigger
# HUBSPOT_DEAL_XERO_SYNC_TRIGGER_VALUE=Sync
# After sync, clear trigger: default is empty string; set true to send JSON null instead; or set a second dropdown option:
# HUBSPOT_DEAL_XERO_SYNC_TRIGGER_CLEAR_SEND_NULL=true
# HUBSPOT_DEAL_XERO_SYNC_TRIGGER_CLEAR_VALUE=your_placeholder_option
# HUBSPOT_DEAL_PROP_LAST_XERO_SYNC=last_xero_sync
# HUBSPOT_DEAL_PROP_XERO_SYNC_LAST_ERROR_DATE=xero_sync_last_error_date
#
# Optional: POST /api/cron/sync-xero (pending trigger queue) — off by default; set false to allow cron to process triggers.
# HUBSPOT_XERO_PENDING_SYNC_CRON_DISABLED=true
#
# Invoice batch sync (in-process timer + POST /api/cron/sync-xero-by-invoice-number). Default: every 90 min, Closed Lost + invoice# + not Paid.
# HUBSPOT_XERO_INVOICE_NUMBER_SYNC_INTERVAL_SECONDS=5400
# HUBSPOT_XERO_INVOICE_NUMBER_SYNC_MAX_DEALS=150
# HUBSPOT_XERO_INVOICE_NUMBER_SYNC_DISABLED=false
# HubSpot internal dealstage id for Closed Lost (Settings → Deals → Pipelines — may be numeric, not the label).
# HUBSPOT_XERO_INVOICE_SYNC_DEALSTAGE_EQ=closedlost
# Comma-separated tokens: batch sync excludes invoice numbers containing these (HubSpot NOT_CONTAINS_TOKEN + in-memory exact match). Default OLD.
# HUBSPOT_XERO_INVOICE_NUMBER_SYNC_IGNORE_VALUES=OLD
# Batch/timer sync: skip deals when HubSpot xero_invoice_status is already Paid (reduces Xero rate limits).
# HUBSPOT_XERO_SKIP_SYNC_WHEN_STATUS_PAID=true
# Use CRM-style HubSpot search (HAS_PROPERTY + not Paid + not contains ignore tokens) so batch size matches filtered lists. Set false for legacy broad HAS_PROPERTY only.
# HUBSPOT_XERO_INVOICE_NUMBER_SYNC_USE_HUBSPOT_FILTERS=true
# Include deals that only have xero_invoice_id (no invoice number). Default false to match "invoice number known" views and reduce Xero calls.
# HUBSPOT_XERO_INVOICE_SYNC_INCLUDE_ID_WITHOUT_NUMBER=false
